    "tuning_rules": [
      {
        "rule_id": "slow_ge_2_5_fast",
        "rule_type": "PARAMETER_RELATIONSHIP",
        "left_parameter": "slow_ema_bars",
        "operator": ">=",
        "right_parameter": "fast_ema_bars",
        "right_multiplier": 2.5,
        "right_offset": 0.0,
        "description": "Keep the slow EMA materially slower than the fast EMA to avoid redundant crossovers."

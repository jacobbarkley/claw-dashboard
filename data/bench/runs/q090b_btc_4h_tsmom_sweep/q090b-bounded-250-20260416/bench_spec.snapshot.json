      {
        "rule_id": "natr_ceiling_gt_floor",
        "rule_type": "PARAMETER_RELATIONSHIP",
        "left_parameter": "natr_ceiling_pct",
        "operator": ">",
        "right_parameter": "natr_floor_pct",
        "right_multiplier": 1.0,
        "right_offset": 0.0,
        "description": "Entry ceiling must remain above the floor."
      }
